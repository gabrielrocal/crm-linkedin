# CRM LinkedIn - Environment Variables
# Copy this file to .env and fill in your values

# Port for the backend server (default: 3001)
PORT=3001

# Proxycurl API Key for LinkedIn profile enrichment
# Sign up at https://nubela.co/proxycurl to get a free API key (10 free credits)
# Without this key, LinkedIn enrichment will be disabled
PROXYCURL_API_KEY=your_proxycurl_api_key_here
